# Copy this file to ".env.local" and paste your real Supabase values.
# Find these in Supabase: Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Resend (order confirmation emails) -> https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Sender for order emails. Only works for ALL customers once you've verified
# your domain in Resend. Until then, leave it unset to use the test sender.
# ORDER_EMAIL_FROM=Toyzilla <orders@yourdomain.com>

# Your live site URL (used for SEO sitemap/robots/canonical links)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Firebase Phone Auth (SMS OTP to verify the signup mobile number).
# Firebase console -> Project settings -> General -> "Your apps" (Web app config).
# Also: Authentication -> Sign-in method -> enable "Phone", and add your domains
# (localhost, *.vercel.app, toyszilla.com) under Authentication -> Settings ->
# Authorized domains.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Razorpay (online payments) -> Dashboard -> Settings -> API Keys
# Use TEST keys (rzp_test_...) while developing. NEVER expose the secret in
# client code — it's only read server-side in the /api/razorpay routes.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
